generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id             Int        @id @default(autoincrement())
  code           String     @unique
  name           String
  brand          String?
  category       String?
  season         String?
  sizeGroup      SizeGroup?
  purchasePrice  Decimal?   @db.Decimal(10, 2)
  salePrice      Decimal?   @db.Decimal(10, 2)
  barcode        String?    @unique
  purchasePrice  Decimal?   @db.Decimal(10, 2)
  salePrice      Decimal?   @db.Decimal(10, 2)
  active         Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  
  variants       Variant[]
}

model Color {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  hexCode    String?
  variants   Variant[]
}

model Size {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  sortOrder  Int
  stocks     Stock[]
  movements  Movement[]
}

model Variant {
  id          Int        @id @default(autoincrement())
  articleId   Int
  colorId     Int
  barcode     String?    @unique

  article     Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  color       Color      @relation(fields: [colorId], references: [id], onDelete: Restrict)
  stocks      Stock[]
  movements   Movement[]

  @@unique([articleId, colorId])
}

model Stock {
  id          Int       @id @default(autoincrement())
  variantId   Int
  sizeId      Int
  quantity    Int       @default(0)
  minQuantity Int       @default(0)
  barcode     String?   @unique
  
  variant     Variant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  size        Size      @relation(fields: [sizeId], references: [id], onDelete: Restrict)

  @@unique([variantId, sizeId])
}

model Movement {
  id          Int           @id @default(autoincrement())
  variantId   Int
  sizeId      Int
  type        MovementType
  quantity    Int
  note        String?
  createdAt   DateTime      @default(now())

  variant     Variant       @relation(fields: [variantId], references: [id], onDelete: Cascade)
  size        Size          @relation(fields: [sizeId], references: [id], onDelete: Restrict)
}

enum MovementType {
  LOAD
  UNLOAD
  INVENTORY
  ADJUSTMENT
}

enum SizeGroup {
  CLOTHING
  PANTS
  SHOES
}